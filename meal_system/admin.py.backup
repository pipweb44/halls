from django.contrib import admin
from django.utils.html import format_html
from .models import Meal, MealImage, MealItem, MealItemImage, MealComponent, MealComponentImage


class MealImageInline(admin.StackedInline):
    model = MealImage
    extra = 1
    fields = ['image', 'caption', 'is_primary']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    verbose_name = 'صورة'
    verbose_name_plural = 'صور الوجبة'


class MealItemImageInline(admin.StackedInline):
    model = MealItemImage
    extra = 1
    fields = ['image', 'caption', 'is_primary']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    verbose_name = 'صورة'
    verbose_name_plural = 'صور الصنف'


class MealItemInline(admin.StackedInline):
    model = MealItem
    extra = 1
    fields = ['name', 'description', 'price', 'is_available', 'order']
    readonly_fields = ['created_at', 'updated_at']
    show_change_link = True
    verbose_name = 'صنف'
    verbose_name_plural = 'أصناف الوجبة'


@admin.register(Meal)
class MealAdmin(admin.ModelAdmin):
    list_display = ['name', 'meal_type', 'price', 'is_available', 'created_at', 'get_primary_image']
    list_filter = ['meal_type', 'is_available']
    search_fields = ['name', 'description']
    inlines = [MealImageInline, MealItemInline]
    fieldsets = [
        ('معلومات الوجبة', {
            'fields': [
                'name', 'description', 'meal_type', 
                'price', 'is_available'
            ]
        }),
        ('التواريخ', {
            'fields': ['created_at', 'updated_at'],
            'classes': ['collapse']
        }),
    ]
    readonly_fields = ['created_at', 'updated_at']
    
    def get_primary_image(self, obj):
        primary_img = obj.images.filter(is_primary=True).first() or obj.images.first()
        if primary_img and hasattr(primary_img, 'image_tag'):
            return primary_img.image_tag()
        return "لا توجد صورة"
    get_primary_image.short_description = 'الصورة الرئيسية'
    get_primary_image.allow_tags = True


@admin.register(MealItem)
class MealItemAdmin(admin.ModelAdmin):
    list_display = ['name', 'get_meal_name', 'price', 'is_available', 'created_at', 'get_primary_image']
    list_filter = ['is_available', 'meal__meal_type']
    search_fields = ['name', 'description', 'meal__name']
    inlines = [MealItemImageInline]
    fieldsets = [
        ('معلومات الصنف', {
            'fields': [
                'meal', 'name', 'description', 
                'price', 'is_available', 'order'
            ]
        }),
        ('التواريخ', {
            'fields': ['created_at', 'updated_at'],
            'classes': ['collapse']
        }),
    ]
    readonly_fields = ['created_at', 'updated_at']
    
    def get_meal_name(self, obj):
        return obj.meal.name if obj.meal else ""
    get_meal_name.short_description = 'الوجبة'
    get_meal_name.admin_order_field = 'meal__name'
    
    def get_primary_image(self, obj):
        primary_img = obj.images.filter(is_primary=True).first() or obj.images.first()
        if primary_img and hasattr(primary_img, 'image_tag'):
            return primary_img.image_tag()
        return "لا توجد صورة"
    get_primary_image.short_description = 'الصورة الرئيسية'
    get_primary_image.allow_tags = True


@admin.register(MealImage)
class MealImageAdmin(admin.ModelAdmin):
    list_display = ['__str__', 'meal', 'is_primary', 'created_at', 'image_tag']
    list_filter = ['is_primary']
    search_fields = ['meal__name', 'caption']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    fields = ['meal', 'image', 'image_tag', 'caption', 'is_primary', 'created_at', 'updated_at']


@admin.register(MealItemImage)
class MealItemImageAdmin(admin.ModelAdmin):
    list_display = ['__str__', 'meal_item', 'is_primary', 'created_at', 'image_tag']
    list_filter = ['is_primary']
    search_fields = ['meal_item__name', 'caption']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    fields = ['meal_item', 'image', 'image_tag', 'caption', 'is_primary', 'created_at', 'updated_at']


class MealComponentImageInline(admin.StackedInline):
    model = MealComponentImage
    extra = 1
    fields = ['image', 'caption', 'is_primary']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    verbose_name = 'صورة'
    verbose_name_plural = 'صور المكون'


@admin.register(MealComponent)
class MealComponentAdmin(admin.ModelAdmin):
    list_display = ['name', 'get_meal_item_name', 'component_type', 'quantity', 'is_optional', 'created_at', 'image_tag']
    list_filter = ['component_type', 'is_optional']
    search_fields = ['name', 'description', 'meal_item__name']
    inlines = [MealComponentImageInline]
    fieldsets = [
        ('معلومات المكون', {
            'fields': [
                'meal_item', 'name', 'component_type', 'description',
                'quantity', 'is_optional', 'order'
            ]
        }),
        ('التواريخ', {
            'fields': ['created_at', 'updated_at'],
            'classes': ['collapse']
        }),
    ]
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    
    def get_meal_item_name(self, obj):
        return obj.meal_item.name if obj.meal_item else ""
    get_meal_item_name.short_description = 'صنف الوجبة'
    get_meal_item_name.admin_order_field = 'meal_item__name'
    
    def image_tag(self, obj):
        primary_img = obj.images.filter(is_primary=True).first() or obj.images.first()
        if primary_img and hasattr(primary_img, 'image_tag'):
            return primary_img.image_tag()
        return "لا توجد صورة"
    image_tag.short_description = 'الصورة الرئيسية'
    image_tag.allow_tags = True


@admin.register(MealComponentImage)
class MealComponentImageAdmin(admin.ModelAdmin):
    list_display = ['__str__', 'component', 'is_primary', 'created_at', 'image_tag']
    list_filter = ['is_primary']
    search_fields = ['component__name', 'caption']
    readonly_fields = ['created_at', 'updated_at', 'image_tag']
    fields = ['component', 'image', 'image_tag', 'caption', 'is_primary', 'created_at', 'updated_at']
